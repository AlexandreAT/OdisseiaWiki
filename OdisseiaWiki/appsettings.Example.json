{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Port=3306;Database=odisseia;Uid=root;Pwd=YOUR_PASSWORD;MaximumPoolSize=10"
  },
  "Database": {
    "ServerVersion": "8.0.0",
    "MaximumPoolSize": 10,
    "ConnectionIdleTimeoutSeconds": 60,
    "RetryCount": 3,
    "RetryDelaySeconds": 5,
    "ApplyMigrationsOnStartup": false,
    "SeedOnStartup": true,
    "InitializationRetrySeconds": 10,
    "InitializationLockTimeoutSeconds": 30
  },
  "ForwardedHeaders": {
    "Enabled": false,
    "KnownProxies": []
  },
  "Jwt": {
    "Issuer": "OdisseiaWiki",
    "Audience": "OdisseiaWiki",
    "ChaveSecreta": "YOUR_SECRET_KEY_WITH_AT_LEAST_32_BYTES",
    "ExpiracaoHoras": 168
  },
  "Authorization": {
    "AdminEmails": [
      "admin@example.com"
    ],
    "RequireVerifiedEmailForAdmin": true
  },
  "GoogleAuth": {
    "ClientId": "YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com"
  },
  "Cors": {
    "AllowedOrigins": [
      "https://your-site.netlify.app"
    ]
  },
  "Uploads": {
    "MaxFileSizeBytes": 10485760
  },
  "Cloudinary": {
    "CloudName": "YOUR_CLOUD_NAME",
    "ApiKey": "YOUR_API_KEY",
    "ApiSecret": "YOUR_API_SECRET",
    "RootFolder": "odisseia",
    "UseLocalStorageInDevelopment": true
  },
  "ImgBB": {
    "ApiKey": "YOUR_API_KEY",
    "Endpoint": "https://api.imgbb.com/1/upload"
  }
}
