{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Port=3306;Database=odisseia;User ID=root;Password=YOUR_MYSQL_PASSWORD;SslMode=None"
  },
  "Database": {
    "ServerVersion": "8.0.0",
    "MaximumPoolSize": 10,
    "ConnectionIdleTimeoutSeconds": 60,
    "RetryCount": 3,
    "RetryDelaySeconds": 5,
    "ApplyMigrationsOnStartup": false,
    "SeedOnStartup": true,
    "InitializationRetrySeconds": 10,
    "InitializationLockTimeoutSeconds": 30
  },
  "Jwt": {
    "Issuer": "OdisseiaWiki.Api",
    "Audience": "OdisseiaWiki.Web",
    "ChaveSecreta": "REPLACE_WITH_A_RANDOM_SECRET_OF_AT_LEAST_32_BYTES",
    "ExpiracaoHoras": 168
  },
  "Authorization": {
    "AdminEmails": ["your-email@example.com"],
    "RequireVerifiedEmailForAdmin": true
  },
  "GoogleAuth": {
    "ClientId": "YOUR_GOOGLE_WEB_CLIENT_ID.apps.googleusercontent.com"
  },
  "Cors": {
    "AllowedOrigins": ["http://localhost:5173"]
  },
  "Uploads": {
    "MaxFileSizeBytes": 10485760
  },
  "Cloudinary": {
    "CloudName": "OPTIONAL_FOR_LOCAL_STORAGE",
    "ApiKey": "OPTIONAL_FOR_LOCAL_STORAGE",
    "ApiSecret": "OPTIONAL_FOR_LOCAL_STORAGE",
    "RootFolder": "odisseia",
    "UseLocalStorageInDevelopment": true
  },
  "ImgBB": {
    "ApiKey": "OPTIONAL_LEGACY_COMPATIBILITY_KEY",
    "Endpoint": "https://api.imgbb.com/1/upload"
  }
}
