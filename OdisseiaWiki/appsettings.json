{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Database": {
    "ServerVersion": "8.0.0",
    "MaximumPoolSize": 10,
    "ConnectionIdleTimeoutSeconds": 60,
    "RetryCount": 3,
    "RetryDelaySeconds": 5,
    "ApplyMigrationsOnStartup": false,
    "SeedOnStartup": true,
    "InitializationRetrySeconds": 10,
    "InitializationLockTimeoutSeconds": 30
  },
  "ForwardedHeaders": {
    "Enabled": false,
    "KnownProxies": []
  },
  "AllowedHosts": "*"
}
